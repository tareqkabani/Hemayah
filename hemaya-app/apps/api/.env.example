# انسخ هذا الملف إلى .env واملأ القيم من إعدادات Supabase.
# منفذ الـ API (خارج نطاق 3000–3013 المستخدَم للبوّابات).
API_PORT=3020

# اتصال Supabase — نفس قيم بقيّة التطبيقات.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# مفتاح الخدمة — سرّيّ مطلق، يتجاوز RLS. للعمليات الإدارية فقط، لا يُعرَض للعملاء أبداً.
SUPABASE_SERVICE_ROLE_KEY=
